# Скопируйте в .env и настройте под своё окружение:
#   cp .env.example .env

HTTP_HOST_PORT=8080
DB_HOST_PORT=5432
DB_NAME=gamehub
DB_USER=gamehub
DB_PASSWORD=gamehub
ADMINDB_PASSWORD=change-me
VITE_API_BASE=/api

# development | production (в production TEAM_TERRITORY_DEBUG_SOLO_LOBBY=1 запрещён)
GAMEHUB_ENV=development

# Пароли «Я автор» на карточках игр (пусто = кнопка отключена)
PRO_RACING_AUTHOR=
RPS_AUTHOR=
TAMAGOTCHI_AUTHOR=
TEAM_TERRITORY_AUTHOR=
MC2D_AUTHOR=

# Team Territory: solo-лобби только для dev-тестов (в prod всегда 0)
TEAM_TERRITORY_DEBUG_SOLO_LOBBY=0
TT_MIN_PARTICIPANTS=2
TT_REGEN_SEC=120
# Временно 5 для теста challenge; в prod — 120
TT_CHALLENGE_COOLDOWN_SEC=120
TT_CHALLENGE_MATH_SEC=7
TT_CHALLENGE_SEQUENCE_SEC=8
TT_CHALLENGE_MAX_PAINT_START=7
TT_COMBO_BONUS_POINTS=1
