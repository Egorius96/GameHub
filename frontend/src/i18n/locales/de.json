    "petTooltip": "{owner} • {type} • Stimmung: {mood}{online}",
    "guideOk": "OK",
    "guideSections": [
      { "title": "Was bedeuten die Balken", "html": "<p>Dein Haustier hat vier Balken: <b>Gesundheit</b>, <b>Sättigung</b>, <b>Stimmung</b> und <b>Energie</b>. Höherer Sättigungsbalken — satter. Energie: laufen/spielen senkt sie, schlafen erhöht sie.</p>" },
      { "title": "Gesundheit wiederherstellen", "html": "<ul><li><b>Schlafen</b>: Gesundheit regeneriert ~2× schneller, wenn es nicht sehr hungrig ist (gilt auch für Energie).</li><li><b>+10% HP</b> fügt sofort 10% für <b>30 Münzen</b> hinzu.</li><li>Nicht stark hungrig oder erschöpft werden lassen.</li></ul>" },
      { "title": "Sättigung wiederherstellen", "html": "<p>Klicke <b>Füttern</b>, wenn du Futter für deinen Typ hast. Futter kaufst du im Shop mit Münzen.</p>" },
      { "title": "Stimmung verbessern", "html": "<p>Klicke <b>Spielen</b> — kostet <b>25 Münzen</b>. Das Spielzeug lässt die Stimmung langsamer sinken.</p>" },
      { "title": "Energie wiederherstellen", "html": "<p>Mit <b>Schlafen legen</b> (<b>10 Münzen</b>) schlafen lassen. ~<b>5 Stunden</b> Schlaf füllen Energie wieder auf. Bei 0 fällt es <b>von selbst</b> in Schlaf.</p>" },
      { "title": "Über Diamanten", "html": "<p>Es sucht Diamanten, wenn es sich gut fühlt. Wenn das <b>durchschnittliche Wohlbefinden</b> zu niedrig ist, startet es nicht. Spielzeug gibt passive Boni und einen <b>10-Minuten-Boost</b> (stapelbar).</p>" },
      { "title": "Warum alles zusammenhängt", "html": "<p>Müde, hungrige oder kranke Haustiere verlieren Energie schneller. Wie bei Menschen.</p>" },
      { "title": "Mit anderen Haustieren auf der Karte", "html": "<p>Wenn eins <b>schläft</b>, spielen/streiten sie nicht. Manchmal kann ein waches ein schlafendes <b>aufwecken</b> — ~<b>1 von 20</b>.</p>" },
      { "title": "Alter und Diamanten", "html": "<p>Je länger es ohne Neuerstellen lebt, desto öfter findet es Diamanten: neu — ~<b>1 Diamant / 2 Min</b>, nach ~3 Monaten — bis <b>1 Diamant / 1 Min</b>.</p>" },
      { "title": "Tipp", "html": "<p class=\"guide-tip\">Tipp: Vor einem langen Spaziergang Energie prüfen und Futter mitnehmen.</p>" }
    ],
